{
  "name": "self-healing-playwright-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright tests with multi-strategy self-healing locators",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "install:browsers": "playwright install chromium",
    "test:traceability": "RUN_TRACEABILITY=1 playwright test tests/traceability",
    "test:auto-heal-live-demo": "playwright test tests/auto-heal-live-demo.spec.ts",
    "test:auto-heal-late-flow-demo": "playwright test tests/auto-heal-late-flow-demo.spec.ts",
    "test:static-healing-showcase": "playwright test --grep @static-healing-showcase",
    "test:auto-heal-discovery-showcase": "playwright test --grep @auto-heal-discovery-showcase",
    "test:healing-showcases": "playwright test --grep \"@static-healing-showcase|@auto-heal-discovery-showcase\"",
    "deck:board": "node scripts/generate-board-deck.mjs",
    "deck:beginner": "node scripts/generate-beginner-technical-deck.mjs",
    "deck:selfhealing": "node scripts/generate-self-healing-beginner-deck.mjs",
    "deck:selfhealing:stepwise": "node scripts/generate-self-healing-stepwise-management-deck.mjs",
    "deck:board:exec": "node scripts/generate-board-exec-low-tech-deck.mjs",
    "deck:pm": "node scripts/generate-pm-presentation-deck.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.10.0",
    "pptxgenjs": "^3.12.0",
    "typescript": "^5.7.0"
  }
}
