{
  "name": "nova-retail-qa",
  "version": "1.0.0",
  "private": true,
  "description": "Nova Retail QA — autonomous tests, healing showcases, traceability (isolated from ai-healing-sdk)",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:traceability": "RUN_TRACEABILITY=1 playwright test tests/traceability",
    "test:healing-showcases": "playwright test --grep \"@static-healing-showcase|@auto-heal-discovery-showcase|@dom-scan-healing-showcase\"",
    "test:autonomous-login": "playwright test tests/autonomous-login.spec.ts",
    "test:autonomous-checkout": "playwright test tests/autonomous-checkout.spec.ts",
    "test:autonomous-ci-smoke": "RUN_AUTONOMOUS_CI=1 playwright test tests/autonomous-ci-smoke.spec.ts",
    "test:autonomous-llm-login": "RUN_AUTONOMOUS_LLM=1 playwright test tests/autonomous-login-llm.spec.ts",
    "test:autonomous-eval": "RUN_AUTONOMOUS_EVAL=1 RUN_AUTONOMOUS_LLM=1 AUTONOMOUS_ALLOW_LLM_IN_CI=1 playwright test tests/autonomous-evaluation.spec.ts",
    "test:autonomous-held-out": "RUN_AUTONOMOUS_HELD_OUT=1 RUN_AUTONOMOUS_LLM=1 AUTONOMOUS_PLANNER=llm AUTONOMOUS_ALLOW_LLM_IN_CI=1 AUTONOMOUS_LLM_VERIFY=1 playwright test tests/autonomous-held-out.spec.ts",
    "test:unit": "RUN_UNIT_TESTS=1 playwright test tests/*.unit.spec.ts",
    "publish:maintenance-tickets": "MAINTENANCE_PUBLISH_JIRA=1 node scripts/publish-maintenance-tickets.mjs",
    "publish:ci-jira-ticket": "MAINTENANCE_PUBLISH_JIRA=1 node scripts/publish-ci-jira-ticket.mjs",
    "maintenance:approve": "node scripts/approve-maintenance-proposal.mjs",
    "maintenance:open-pr": "node scripts/open-maintenance-pr.mjs",
    "write:autonomous-kpis": "node scripts/write-autonomous-kpis.mjs"
  },
  "dependencies": {
    "ai-healing-sdk": "file:../../packages/ai-healing-sdk",
    "autonomous-qa-sdk": "file:../../packages/autonomous-qa-sdk",
    "autonomous-agent-contracts": "file:../../packages/autonomous-agent-contracts",
    "autonomous-test-agent": "file:../../agents/autonomous-test-agent"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
